#include <stdio.h>
int a[10];
int top=-1;
void push (int val){
    if(top==9){
        printf("stack is full\n");
} else{
       top++;
       a[top]=val;
    }
}
void pop(){
    if(top==-1){
        printf("stack is empty\n");
    }else{
        printf("%d\n", a[top]);
        top--;
    }
}
int main(){
    push(10);
    push(20);
    push(30);
    pop();
    pop();
    pop();
    pop();
    return 0;
}
