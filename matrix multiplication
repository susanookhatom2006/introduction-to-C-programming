#include <stdio.h>
int main(){
    int A [3][4],B[4][2], result[3][2];
    int i, j, k;
    for(i=0; i<3; i++){
        for(j=0; j<4; i++){
            scanf("%d", &A[i][j]);
        }
    }
    for(i=0; i<4; i++){
        for(j=0;j<2; j++){
            scanf("%d", &B[i][j]);
        }
    }
    for(i=0; i<3; i++){
        for(j=0; j<2; j++){
            result[i][j]=0;
            for(k=0; k<4; k++){
                result[i][j]=0;
                for(k=0; k<4; k++){
                    result[i][j]+=A[i][k]*B[k][j];                }
            }
        }
    }
    printf("\n resultant 3*2 matrix:\n");
    for(i=0; i<3; i++){
        for(j=0; j<2; j++){
            printf("%d\t", result[i][j]);
        }
        printf("\n");
    }
    return 0;
    
